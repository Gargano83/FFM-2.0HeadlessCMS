@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-4">
    <h1 class="h3 mb-0">Dashboard</h1>
    <p class="text-muted mb-0">Riepilogo del backoffice.</p>
</div>

<div class="row row-cols-2 row-cols-md-4 g-3 mb-4">
    <div class="col">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Entità scaffoldate</div>
                <div class="fs-3 fw-semibold">@Model.Counters.ScaffoldedEntities</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Pagine</div>
                <div class="fs-3 fw-semibold">@Model.Counters.Pages</div>
                <div class="text-muted small">@Model.Counters.PublishedPages pubblicate</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Voci di menu</div>
                <div class="fs-3 fw-semibold">@Model.Counters.MenuItems</div>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Utenti</div>
                <div class="fs-3 fw-semibold">@(Model.Counters.AdminUsers + Model.Counters.EditorUsers + Model.Counters.OperatorUsers)</div>
                <div class="text-muted small">
                    @Model.Counters.AdminUsers admin &middot; @Model.Counters.EditorUsers editor &middot; @Model.Counters.OperatorUsers operator
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
                <h2 class="h6 mb-0">Attività recente</h2>
                <span class="text-muted small">Pagine, Menu, Utenti</span>
            </div>
            <div class="card-body pt-0">
                @if (Model.RecentAuditEntries.Count == 0)
                {
                    <p class="text-muted small mb-0">Nessuna attività registrata.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var entry in Model.RecentAuditEntries)
                        {
                            <li class="d-flex align-items-start gap-2 py-2 border-bottom">
                                <span class="badge @ActionBadgeClass(entry.Action) mt-1" style="min-width:64px;">@ActionLabel(entry.Action)</span>
                                <div>
                                    <div class="small">@(entry.Summary ?? entry.EntityType)</div>
                                    <div class="text-muted small">
                                        @(entry.UserEmail ?? "Sistema") &middot; @entry.TimestampUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-3">
                <h2 class="h6 mb-0">Pagine recenti</h2>
            </div>
            <div class="card-body pt-0">
                @if (Model.RecentPages.Count == 0)
                {
                    <p class="text-muted small mb-0">Nessuna pagina creata.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var recentPage in Model.RecentPages)
                        {
                            <li class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                <div>
                                    <a href="/dami/pages/@recentPage.Id/edit" class="text-decoration-none">@recentPage.Title</a>
                                    <div class="text-muted small">/@recentPage.Slug</div>
                                </div>
                                <div class="text-end">
                                    @if (recentPage.IsPublished)
                                    {
                                        <span class="badge bg-success-subtle text-success">Pubblicata</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary">Bozza</span>
                                    }
                                    <div class="text-muted small">@((recentPage.UpdatedAtUtc ?? recentPage.CreatedAtUtc).ToLocalTime().ToString("dd/MM/yyyy"))</div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

<h2 class="h5 mb-3">Entità gestite</h2>

@if (Model.Entities.Count == 0)
{
    <div class="alert alert-info">Nessuna entità scaffoldata. Usa il wizard di scaffolding per iniziare.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
        @foreach (var entity in Model.Entities)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-3 bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center me-3"
                                 style="width:48px;height:48px;">
                                <i class="bi bi-@(entity.Icon ?? "table") fs-4"></i>
                            </div>
                            <div>
                                <div class="fw-semibold text-dark">@entity.DisplayName</div>
                                <div class="text-muted small">@entity.QualifiedTableName</div>
                            </div>
                        </div>
                        <div class="mt-auto d-flex gap-2">
                            <a href="/dami/@entity.Id" class="btn btn-sm btn-primary flex-fill">
                                <i class="bi bi-table me-1"></i> Dati
                            </a>
                            <a href="/dami/@entity.Id/structure" class="btn btn-sm btn-outline-secondary flex-fill">
                                <i class="bi bi-diagram-3 me-1"></i> Struttura
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@functions {
    private static string ActionBadgeClass(string action) => action switch
    {
        "Create" => "bg-success-subtle text-success",
        "Update" => "bg-primary-subtle text-primary",
        "Delete" => "bg-danger-subtle text-danger",
        _ => "bg-secondary-subtle text-secondary"
    };

    private static string ActionLabel(string action) => action switch
    {
        "Create" => "Creato",
        "Update" => "Modificato",
        "Delete" => "Eliminato",
        _ => action
    };
}

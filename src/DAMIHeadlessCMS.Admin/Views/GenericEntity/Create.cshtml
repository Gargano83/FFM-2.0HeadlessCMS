@model GenericEntityFormViewModel
@{
    ViewData["Title"] = $"Nuovo — {Model.Entity.DisplayName}";
}

<h1 class="h3 mb-4">Nuovo — @Model.Entity.DisplayName</h1>

<form method="post" action="/dami/@Model.Entity.Id/create" enctype="multipart/form-data" class="card border-0 shadow-sm p-4">
    @Html.AntiForgeryToken()
    <partial name="_EntityForm" model="Model" />
</form>
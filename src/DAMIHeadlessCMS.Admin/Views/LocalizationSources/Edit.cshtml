@model LocalizationSourceFormViewModel
@{
    ViewData["Title"] = $"Modifica — {Model.DisplayName}";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item"><a href="/dami/localization-sources">Localizzazioni</a></li>
            <li class="breadcrumb-item active">@Model.DisplayName</li>
        </ol>
    </nav>
    <h1 class="h3 mb-0">Modifica sorgente di localizzazione</h1>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}

<form method="post" action="/dami/localization-sources/@Model.Id/edit" class="card border-0 shadow-sm p-4">
    @Html.AntiForgeryToken()
    <partial name="_Form" model="Model" />
</form>
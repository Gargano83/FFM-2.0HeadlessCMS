@model IReadOnlyList<UserListItemViewModel>
@{
    ViewData["Title"] = "Utenti";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="/backoffice/admin">Entità</a></li>
                <li class="breadcrumb-item active">Utenti</li>
            </ol>
        </nav>
        <h1 class="h3 mb-0">Utenti del backoffice</h1>
    </div>
    <a href="/backoffice/admin/users/create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i> Nuovo utente
    </a>
</div>

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Email</th>
                    <th>Nome</th>
                    <th>Ruoli</th>
                    <th class="text-center">Stato</th>
                    <th class="text-end">Azioni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Email</td>
                        <td>@(user.DisplayName ?? "—")</td>
                        <td>
                            @foreach (var role in user.Roles)
                            {
                                <span class="badge bg-primary-subtle text-primary me-1">@role</span>
                            }
                            @if (user.Roles.Count == 0)
                            {
                                <span class="text-muted small">Nessun ruolo</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (user.IsLockedOut)
                            {
                                <span class="badge bg-danger-subtle text-danger">Disabilitato</span>
                            }
                            else
                            {
                                <span class="badge bg-success-subtle text-success">Attivo</span>
                            }
                        </td>
                        <td class="text-end">
                            <a href="/backoffice/admin/users/@user.Id/edit" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="/backoffice/admin/users/@user.Id/toggle-lock" class="d-inline"
                                  onsubmit="return confirm('@(user.IsLockedOut ? "Riabilitare" : "Disabilitare") questo utente?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-@(user.IsLockedOut ? "success" : "danger")">
                                    <i class="bi bi-@(user.IsLockedOut ? "unlock" : "lock")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Nessun utente.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - MyCms Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" 
          crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --cms-sidebar-width: 260px;
        }
        body { background-color: #f5f6f8; }
        .cms-sidebar {
            width: var(--cms-sidebar-width);
            min-height: 100vh;
            background: #1a1d29;
        }
        .cms-sidebar .nav-link { color: #b8bcc8; }
        .cms-sidebar .nav-link.active, .cms-sidebar .nav-link:hover { color: #fff; background: rgba(255,255,255,.06); }
        .cms-content { flex: 1; min-width: 0; }
        @@media (max-width: 991.98px) {
            .cms-sidebar { position: fixed; z-index: 1045; transform: translateX(-100%); transition: transform .2s ease; }
            .cms-sidebar.show { transform: translateX(0); }
        }
    </style>
</head>
<body>
    <div class="d-flex">
        <nav class="cms-sidebar d-flex flex-column p-3" id="cmsSidebar">
            <a href="/cms-admin/entities" class="d-flex align-items-center mb-4 text-white text-decoration-none">
                <i class="bi bi-layers-fill fs-4 me-2"></i>
                <span class="fs-5 fw-semibold">MyCms</span>
            </a>
            <ul class="nav nav-pills flex-column mb-auto" id="cmsEntityNav">
                <!-- Popolato dalla view Index -->
            </ul>
        </nav>

        <div class="cms-content">
            <nav class="navbar navbar-light bg-white border-bottom px-3 d-lg-none">
                <button class="btn btn-outline-secondary" type="button" onclick="document.getElementById('cmsSidebar').classList.toggle('show')">
                    <i class="bi bi-list"></i>
                </button>
                <span class="navbar-brand mb-0 h1">MyCms</span>
            </nav>

            <main class="container-fluid p-3 p-lg-4">
                @if (TempData["StatusMessage"] is string statusMessage)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @statusMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
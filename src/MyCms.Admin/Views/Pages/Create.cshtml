@model PageFormViewModel
@{
    ViewData["Title"] = "Nuova pagina";
}

<div class="mb-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-1">
            <li class="breadcrumb-item"><a href="/backoffice/admin/pages">Pagine</a></li>
            <li class="breadcrumb-item active">Nuova</li>
        </ol>
    </nav>
    <h1 class="h3 mb-0">Nuova pagina</h1>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}

<form method="post" action="/backoffice/admin/pages/create" class="card border-0 shadow-sm p-4">
    @Html.AntiForgeryToken()
    <partial name="_PageForm" model="Model" />
</form>
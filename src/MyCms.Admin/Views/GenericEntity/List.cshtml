@model GenericEntityIndexViewModel
@{
    ViewData["Title"] = Model.Entity.DisplayName;
    var listFields = Model.Entity.Fields.Where(f => f.ShowInList).OrderBy(f => f.SortOrder).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a href="/backoffice/admin">Entità</a></li>
                <li class="breadcrumb-item active">@Model.Entity.DisplayName</li>
            </ol>
        </nav>
        <h1 class="h3 mb-0">@Model.Entity.DisplayName</h1>
    </div>
    <a href="/backoffice/admin/@Model.Entity.Id/create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Nuovo
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    @foreach (var field in listFields)
                    {
                        <th>@field.DisplayName</th>
                    }
                    <th class="text-end">Azioni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Rows)
                {
                    var pkField = Model.Entity.Fields.First(f => f.IsPrimaryKey);
                    var recordId = row[pkField.ColumnName]?.ToString();
                    <tr>
                        @foreach (var field in listFields)
                        {
                            <td>
                                @if (field.EditorType == EditorType.Checkbox)
                                {
                                    var isTrue = row[field.ColumnName] is true;
                                    <span class="badge bg-@(isTrue ? "success" : "secondary")">@(isTrue ? "Sì" : "No")</span>
                                }
                                else
                                {
                                    @row[field.ColumnName]
                                }
                            </td>
                        }
                        <td class="text-end">
                            <a href="/backoffice/admin/@Model.Entity.Id/edit/@recordId" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="/backoffice/admin/@Model.Entity.Id/delete/@recordId"
                                  class="d-inline" onsubmit="return confirm('Eliminare questo elemento?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (Model.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="@(listFields.Count + 1)" class="text-center text-muted py-4">Nessun elemento.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (var p = 1; p <= Model.TotalPages; p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : "")">
                    <a class="page-link" href="/backoffice/admin/@Model.Entity.Id?page=@p">@p</a>
                </li>
            }
        </ul>
    </nav>
}
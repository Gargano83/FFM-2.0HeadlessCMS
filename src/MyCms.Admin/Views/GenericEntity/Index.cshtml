@model IReadOnlyList<EntityDefinition>
@{
    ViewData["Title"] = "Entità";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Entità gestite</h1>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Nessuna entità scaffoldata. Usa il wizard di scaffolding per iniziare.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
        @foreach (var entity in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-3 bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center me-3"
                                 style="width:48px;height:48px;">
                                <i class="bi bi-@(entity.Icon ?? "table") fs-4"></i>
                            </div>
                            <div>
                                <div class="fw-semibold text-dark">@entity.DisplayName</div>
                                <div class="text-muted small">@entity.QualifiedTableName</div>
                            </div>
                        </div>
                        <div class="mt-auto d-flex gap-2">
                            <a href="/dami/@entity.Id" class="btn btn-sm btn-primary flex-fill">
                                <i class="bi bi-table me-1"></i> Dati
                            </a>
                            <a href="/dami/@entity.Id/structure" class="btn btn-sm btn-outline-secondary flex-fill">
                                <i class="bi bi-diagram-3 me-1"></i> Struttura
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        const nav = document.getElementById('cmsEntityNav');
        const entities = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(e => new { e.Id, e.DisplayName, e.Icon })));
        const currentPath = window.location.pathname;

        entities.forEach(e => {
            const isActive = currentPath.startsWith(`/dami/${e.Id}`);
            const li = document.createElement('li');
            li.innerHTML = `<a href="/dami/${e.Id}" class="cms-nav-link${isActive ? ' active' : ''}">
                <i class="bi bi-${e.Icon ?? 'table'}"></i> <span>${e.DisplayName}</span>
            </a>`;
            nav.appendChild(li);
        });
    </script>
}
@model GenericEntityFormViewModel
@{
    var formFields = Model.Entity.Fields.Where(f => f.ShowInForm).OrderBy(f => f.SortOrder).ToList();
}

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row g-3">
    @foreach (var field in formFields)
    {
        var value = Model.Values?.GetValueOrDefault(field.ColumnName);
        <div class="col-12 col-md-6">
            <label class="form-label fw-medium" for="field_@field.ColumnName">
                @field.DisplayName
                @if (field.IsRequired)
                {
                    <span class="text-danger">*</span>
                }
            </label>

            @switch (field.EditorType)
            {
                case EditorType.TextArea:
                    <textarea class="form-control" id="field_@field.ColumnName" name="@field.ColumnName"
                              rows="4" maxlength="@field.MaxLength" required="@field.IsRequired">@value</textarea>
                    break;

                case EditorType.RichText:
                    <div class="cms-richtext-wrapper">
                        <textarea class="form-control" id="field_@field.ColumnName" name="@field.ColumnName" rows="6">@value</textarea>
                    </div>
                    break;

                case EditorType.Number:
                    <input type="number" step="any" class="form-control" id="field_@field.ColumnName"
                           name="@field.ColumnName" value="@value" required="@field.IsRequired" />
                    break;

                case EditorType.Checkbox:
                    var isChecked = value is true;
                    <div class="form-check form-switch mt-2">
                        <input type="checkbox" class="form-check-input" id="field_@field.ColumnName"
                               name="@field.ColumnName" value="true" checked="@isChecked" />
                    </div>
                    break;

                case EditorType.Date:
                    <input type="date" class="form-control" id="field_@field.ColumnName"
                           name="@field.ColumnName" value="@(value as DateTime?)?.ToString(" yyyy-MM-dd")"
                           required="@field.IsRequired" />
                    break;

                case EditorType.DateTime:
                    <input type="datetime-local" class="form-control" id="field_@field.ColumnName"
                           name="@field.ColumnName" value="@(value as DateTime?)?.ToString(" yyyy-MM-ddTHH:mm")"
                           required="@field.IsRequired" />
                    break;

                case EditorType.Select:
                    var fkValue = value?.ToString();
                    <div class="cms-fk-autocomplete" data-field-id="@field.Id" data-selected-value="@fkValue">
                        <input type="text" class="form-control cms-fk-search" placeholder="Cerca..." autocomplete="off" />
                        <input type="hidden" class="cms-fk-value" name="@field.ColumnName" value="@fkValue" />
                        <div class="cms-fk-dropdown list-group shadow-sm d-none"></div>
                    </div>
                    break;

                case EditorType.File:
                    var isBinaryColumn = field.SqlDataType.ToLowerInvariant() is "varbinary" or "binary" or "image";
                    <input type="file" class="form-control cms-file-input" id="field_@field.ColumnName" name="@field.ColumnName" />
                    @if (!isBinaryColumn && value is string existingPath && !string.IsNullOrWhiteSpace(existingPath))
                    {
                        <div class="form-text">
                            File attuale: <a href="/@existingPath" target="_blank">@System.IO.Path.GetFileName(existingPath)</a>
                            <span class="cms-file-current-name"></span>
                        </div>
                    }
                    else if (isBinaryColumn && value is not null)
                    {
                        <div class="form-text">File binario già presente in database (download non ancora disponibile).</div>
                    }
                    else
                    {
                        <div class="form-text"><span class="cms-file-current-name"></span></div>
                    }
                    break;

                case EditorType.Hidden:
                    <input type="hidden" id="field_@field.ColumnName" name="@field.ColumnName" value="@value" />
                    break;

                default: // Text
                         <input type="text" class="form-control" id="field_@field.ColumnName" name="@field.ColumnName"
                                value="@value" maxlength="@field.MaxLength" required="@field.IsRequired" />
                    break;
            }
        </div>
    }
</div>

<div class="mt-4 d-flex gap-2">
    <button type="submit" class="btn btn-primary">
        <i class="bi bi-check-lg me-1"></i> Salva
    </button>
    <a href="/dami/@Model.Entity.Id" class="btn btn-outline-secondary">Annulla</a>
</div>

<link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
<style>
    .cms-fk-autocomplete {
        position: relative;
    }

    .cms-fk-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 20;
        max-height: 220px;
        overflow-y: auto;
    }

    .cms-fk-dropdown .list-group-item {
        cursor: pointer;
        font-size: .9rem;
    }
</style>
<script>
    // --- Autocomplete FK ---
    document.querySelectorAll('.cms-fk-autocomplete').forEach((wrapper) => {
        const fieldId = wrapper.dataset.fieldId;
        const selectedValue = wrapper.dataset.selectedValue;
        const searchInput = wrapper.querySelector('.cms-fk-search');
        const hiddenInput = wrapper.querySelector('.cms-fk-value');
        const dropdown = wrapper.querySelector('.cms-fk-dropdown');
        let debounceTimer = null;

        if (selectedValue) {
            fetch(`/dami/lookup/${fieldId}/label?id=${encodeURIComponent(selectedValue)}`)
            .then(r => r.ok ? r.json() : null)
            .then(data => { if (data) searchInput.value = data.label; })
            .catch(() => {});
        }

        function renderOptions(options) {
            dropdown.innerHTML = '';
            if (options.length === 0) {
                dropdown.innerHTML = '<div class="list-group-item text-muted small">Nessun risultato</div>';
            } else {
                options.forEach(opt => {
                    const item = document.createElement('button');
                    item.type = 'button';
                    item.className = 'list-group-item list-group-item-action';
                    item.textContent = opt.label;
                    item.addEventListener('click', () => {
                        hiddenInput.value = opt.value;
                        searchInput.value = opt.label;
                        dropdown.classList.add('d-none');
                    });
                    dropdown.appendChild(item);
                });
            }
            dropdown.classList.remove('d-none');
        }

        searchInput.addEventListener('input', () => {
            clearTimeout(debounceTimer);
            const q = searchInput.value.trim();
            debounceTimer = setTimeout(async () => {
                try {
                    const res = await fetch(`/dami/lookup/${fieldId}?q=${encodeURIComponent(q)}`);
                    if (!res.ok) return;
                    renderOptions(await res.json());
                } catch { /* silenzioso */ }
            }, 300);
        });

        searchInput.addEventListener('focus', () => {
            if (dropdown.children.length > 0) dropdown.classList.remove('d-none');
        });

        document.addEventListener('click', (e) => {
            if (!wrapper.contains(e.target)) dropdown.classList.add('d-none');
        });
    });

    // --- RichText (Quill) ---
    document.querySelectorAll('.cms-richtext-wrapper').forEach((wrapper) => {
        const textarea = wrapper.querySelector('textarea');
        const editorDiv = document.createElement('div');
        editorDiv.style.minHeight = '160px';
        editorDiv.style.background = '#fff';
        wrapper.appendChild(editorDiv);
        textarea.classList.add('d-none');

        const quill = new Quill(editorDiv, { theme: 'snow' });
        quill.root.innerHTML = textarea.value || '';
        quill.on('text-change', () => {
            textarea.value = quill.root.innerHTML;
        });
    });

    // --- File: mostra il nome del file appena selezionato ---
    document.querySelectorAll('.cms-file-input').forEach((input) => {
        input.addEventListener('change', () => {
            const label = input.closest('.col-12')?.querySelector('.cms-file-current-name');
            if (label) label.textContent = input.files[0] ? `Nuovo file: ${input.files[0].name}` : '';
        });
    });
</script>